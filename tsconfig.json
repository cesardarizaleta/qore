{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "moduleResolution": "node10",
    "ignoreDeprecations": "5.0",
    "module": "CommonJS",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "bench", "__test__"]
}
